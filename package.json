{
  "name": "@aigate/cli",
  "version": "0.0.0",
  "description": "AI Git Workflow Guard CLI for checks, reports, project evaluation, and branch strategy design.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/LeeHueeng/aigate-ai-git-workflow-guard-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeeHueeng/aigate-ai-git-workflow-guard-cli.git"
  },
  "bugs": {
    "url": "https://github.com/LeeHueeng/aigate-ai-git-workflow-guard-cli/issues"
  },
  "bin": {
    "aigate": "./src/cli.mjs"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "aigate:check": "node src/cli.mjs check",
    "aigate:git-ready": "node src/cli.mjs git-ready",
    "check": "node --check src/cli.mjs",
    "ci": "npm run check && npm test && npm run aigate:git-ready && npm pack --dry-run",
    "git:ready": "npm run ci",
    "prepare:push": "npm run git:ready && node src/cli.mjs report --format markdown",
    "test": "node --test",
    "start": "node src/cli.mjs"
  },
  "keywords": [
    "git",
    "cli",
    "workflow",
    "branch-strategy",
    "pull-request",
    "repository-health",
    "developer-tools",
    "devops",
    "ai"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  }
}
